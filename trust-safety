<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --bg:        #0e0d0b;
    --bg-card:   #161510;
    --bg-mid:    #1e1c17;
    --border:    rgba(255,255,255,0.07);
    --border-em: rgba(255,255,255,0.14);
    --text:      #ede8da;
    --muted:     #8a8478;
    --faint:     #4a4740;
    --amber:     #c9963a;
    --amber-dim: #7a5820;
    --amber-bg:  rgba(201,150,58,0.08);
    --green-bg:  rgba(100,170,100,0.08);
    --green:     #6aad6a;
    --red-bg:    rgba(190,90,90,0.08);
    --red:       #c46a6a;
    --blue-bg:   rgba(80,130,200,0.08);
    --blue:      #6ea0d4;
    --violet-bg: rgba(130,100,200,0.08);
    --violet:    #a080d4;
    --teal-bg:   rgba(60,160,160,0.08);
    --teal:      #4db8b8;
    --teal-dim:  #1e5858;
    --serif:     'Playfair Display', Georgia, serif;
    --sans:      'DM Sans', system-ui, sans-serif;
    --mono:      'DM Mono', monospace;
  }
  html { font-size: 16px; }
  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--sans);
    font-weight: 300;
    line-height: 1.7;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
  }
  .outer { max-width: 780px; margin: 0 auto; padding: 0 1.5rem 6rem; }

  header { padding: 4rem 0 2.5rem; border-bottom: 0.5px solid var(--border); margin-bottom: 3rem; }
  .header-label { font-family: var(--mono); font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--amber); margin-bottom: 1rem; }
  header h1 { font-family: var(--serif); font-weight: 400; font-size: clamp(2rem, 5vw, 2.8rem); line-height: 1.2; color: var(--text); margin-bottom: 0.75rem; }
  header h1 em { font-style: italic; color: var(--muted); }
  .header-note { margin-top: 1.25rem; font-size: 13px; color: var(--muted); max-width: 580px; line-height: 1.65; }
  .header-meta { display: flex; flex-wrap: wrap; gap: 1.5rem; margin-top: 1.5rem; padding-top: 1.5rem; border-top: 0.5px solid var(--border); }
  .meta-item { font-size: 12px; color: var(--muted); }
  .meta-item strong { color: var(--text); font-weight: 400; display: block; font-size: 13px; }

  .tab-row { display: flex; gap: 4px; margin-bottom: 2.5rem; flex-wrap: wrap; }
  .tab-btn { background: none; border: 0.5px solid var(--border); color: var(--muted); font-family: var(--sans); font-size: 12px; font-weight: 400; letter-spacing: 0.04em; padding: 7px 16px; border-radius: 40px; cursor: pointer; transition: all 0.18s; }
  .tab-btn:hover { border-color: var(--border-em); color: var(--text); }
  .tab-btn.active { background: var(--amber-bg); border-color: var(--amber-dim); color: var(--amber); }
  .tab-panel { display: none; }
  .tab-panel.active { display: block; }

  .section-intro { font-size: 13px; color: var(--muted); margin-bottom: 2rem; max-width: 580px; line-height: 1.65; }

  .case-card { border: 0.5px solid var(--border); border-radius: 12px; padding: 1.75rem; margin-bottom: 1.25rem; background: var(--bg-card); transition: border-color 0.2s; }
  .case-card:hover { border-color: var(--border-em); }

  .case-meta { display: flex; align-items: center; gap: 6px; margin-bottom: 1rem; flex-wrap: wrap; }
  .badge { font-family: var(--mono); font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; padding: 3px 9px; border-radius: 4px; font-weight: 500; }
  .b-policy  { background: var(--blue-bg);   color: var(--blue);   border: 0.5px solid rgba(110,160,212,0.2); }
  .b-edge    { background: var(--amber-bg);  color: var(--amber);  border: 0.5px solid rgba(201,150,58,0.2); }
  .b-esc     { background: var(--red-bg);    color: var(--red);    border: 0.5px solid rgba(196,106,106,0.2); }
  .b-ok      { background: var(--green-bg);  color: var(--green);  border: 0.5px solid rgba(106,173,106,0.2); }
  .b-up      { background: var(--violet-bg); color: var(--violet); border: 0.5px solid rgba(160,128,212,0.2); }
  .b-neutral { background: rgba(255,255,255,0.04); color: var(--muted); border: 0.5px solid var(--border); }
  .b-ai      { background: var(--teal-bg);   color: var(--teal);   border: 0.5px solid rgba(77,184,184,0.2); }

  .case-title { font-family: var(--serif); font-size: 1.15rem; font-weight: 400; color: var(--text); margin-bottom: 1rem; line-height: 1.35; }

  .scenario { background: var(--bg-mid); border-left: 2px solid var(--amber-dim); border-radius: 0 6px 6px 0; padding: 0.85rem 1rem; margin-bottom: 1.25rem; font-size: 13px; color: var(--muted); line-height: 1.65; }
  .scenario strong { color: var(--text); font-weight: 400; }

  .s-label { font-family: var(--mono); font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--faint); margin: 1.1rem 0 0.6rem; }

  .tension-row { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 1rem; }
  @media (max-width: 520px) { .tension-row { grid-template-columns: 1fr; } }
  .tension-side { border-radius: 6px; padding: 0.75rem; font-size: 12.5px; line-height: 1.55; }
  .t-restrict { background: var(--red-bg); border-left: 2px solid var(--red); color: #c48080; }
  .t-permit   { background: var(--green-bg); border-left: 2px solid var(--green); color: #80b880; }
  .t-head { font-family: var(--mono); font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase; opacity: 0.7; margin-bottom: 4px; }
  .t-restrict .t-head { color: var(--red); }
  .t-permit   .t-head { color: var(--green); }

  .reason { display: flex; gap: 10px; margin-bottom: 0.65rem; align-items: flex-start; font-size: 13px; line-height: 1.65; color: var(--muted); }
  .reason::before { content: ''; display: block; width: 4px; height: 4px; min-width: 4px; border-radius: 50%; background: var(--faint); margin-top: 8px; flex-shrink: 0; }

  .signal-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; margin-bottom: 1rem; }
  @media (max-width: 520px) { .signal-grid { grid-template-columns: 1fr; } }
  .signal { background: var(--bg-mid); border-radius: 6px; padding: 0.6rem 0.75rem; font-size: 12px; color: var(--muted); line-height: 1.45; display: flex; gap: 6px; align-items: flex-start; }
  .sig-icon { flex-shrink: 0; margin-top: 1px; }
  .sig-warn { color: var(--amber); }
  .sig-ok   { color: var(--green); }

  .priority-row { display: flex; align-items: center; gap: 10px; margin-bottom: 1rem; }
  .priority-label { font-size: 11px; color: var(--muted); white-space: nowrap; font-family: var(--mono); }
  .pbar { flex: 1; height: 4px; background: var(--bg-mid); border-radius: 2px; overflow: hidden; border: 0.5px solid var(--border); }
  .pfill { height: 100%; border-radius: 2px; }
  .p-crit { background: var(--red);   width: 100%; }
  .p-high { background: #d48060;      width: 75%; }
  .p-mid  { background: var(--amber); width: 50%; }

  .verdict { border-top: 0.5px solid var(--border); margin-top: 1.25rem; padding-top: 1.1rem; display: flex; gap: 12px; align-items: flex-start; }
  .verdict-label { font-family: var(--mono); font-size: 9px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--amber); flex-shrink: 0; padding-top: 3px; min-width: 56px; }
  .verdict-text { font-size: 13px; color: var(--text); line-height: 1.6; font-weight: 300; }

  .impact { margin-top: 8px; padding-top: 8px; border-top: 0.5px dashed rgba(77,184,184,0.15); display: flex; gap: 12px; align-items: flex-start; }
  .impact-label { font-family: var(--mono); font-size: 9px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--teal); flex-shrink: 0; padding-top: 3px; min-width: 56px; }
  .impact-text { font-size: 12px; color: var(--muted); line-height: 1.55; font-style: italic; }

  .anchor-callout { background: rgba(77,184,184,0.05); border: 0.5px solid rgba(77,184,184,0.18); border-radius: 6px; padding: 0.55rem 0.9rem; margin-top: 0.7rem; font-size: 11.5px; color: var(--teal); font-family: var(--mono); letter-spacing: 0.02em; line-height: 1.5; }

  footer { border-top: 0.5px solid var(--border); margin-top: 4rem; padding-top: 2rem; display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; gap: 1rem; }
  .footer-name { font-family: var(--serif); font-size: 1.1rem; color: var(--text); margin-bottom: 4px; }
  .footer-sub { font-size: 12px; color: var(--muted); }
  .footer-links { display: flex; gap: 1.25rem; align-items: center; }
  .footer-links a { font-size: 12px; color: var(--muted); text-decoration: none; font-family: var(--mono); letter-spacing: 0.04em; transition: color 0.15s; }
  .footer-links a:hover { color: var(--amber); }
</style>
